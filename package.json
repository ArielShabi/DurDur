{
  "name": "durak-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @durak/server",
    "dev:client": "npm run dev -w @durak/client",
    "build": "npm run build -w @durak/server && npm run build -w @durak/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
